# Back4App credentials
BACK4APP_EMAIL=
BACK4APP_PASSWORD=
# Cookie generated by get_cookie.py
BACK4APP_COOKIE=
# Multi-app deployment mapping, example: {"app_id":"service_env_id"}
APP_ID_MAP_JSON={}
# Cron expression used by scheduler.py
CRON_SCHEDULE=*/1 * * * *
# Exposed port for the health check server
PORT=7860
# Log level, example: DEBUG INFO WARNING ERROR
LOG_LEVEL=INFO
# Run once immediately after container start
RUN_ON_STARTUP=true
